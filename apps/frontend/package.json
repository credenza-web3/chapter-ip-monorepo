{
  "name": "frontend",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "format": "prettier --write .",
    "lint": "prettier --check . && eslint .",
    "test:unit": "vitest",
    "test": "npm run test:unit -- --run"
  },
  "devDependencies": {
    "@repo/content-types": "workspace:*",
    "@repo/eslint-config": "workspace:*",
    "@repo/fe-auth": "workspace:*",
    "@repo/fe-config": "workspace:*",
    "@repo/fe-evm-provider": "workspace:*",
    "@repo/fe-services": "workspace:*",
    "@repo/trpc": "workspace:*",
    "@repo/ui-components": "workspace:*",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.70.1",
    "@sveltejs/vite-plugin-svelte": "^7.2.0",
    "@types/node": "^26",
    "@vitest/browser": "^4.1.10",
    "@vitest/browser-playwright": "^4.1.10",
    "eslint": "^10.7.0",
    "playwright": "^1.61.1",
    "prettier": "^3.9.6",
    "prettier-plugin-svelte": "^4.1.1",
    "svelte": "^5.56.7",
    "svelte-check": "^4.7.3",
    "typescript": "^6.0.3",
    "vite": "^8.1.5",
    "vitest": "^4.1.10",
    "vitest-browser-svelte": "^3.0.0",
    "yaml": "^2.9.0"
  },
  "dependencies": {
    "@credenza3/contracts": "^0.0.21",
    "@credenza3/passport-evm": "^0.4.31",
    "@tailwindcss/vite": "^4.3.3",
    "client-zip": "^2.5.0",
    "daisyui": "^5.7.0",
    "mime": "^4.1.0",
    "native-file-system-adapter": "^3.0.1",
    "svelte-modals": "^2.0.1",
    "tailwindcss": "^4.3.3"
  }
}
