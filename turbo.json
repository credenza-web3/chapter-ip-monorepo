{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "tui",
  "globalEnv": ["PORT", "NODE_ENV", "ACCOUNTS_URL"],
  "tasks": {
    "//#trpc:generate": {
      "cache": true,
      "persistent": false
    },
    "//#trpc:watch": {
      "persistent": true,
      "cache": true
    },
    "backend#dev": {
      "with": ["//#trpc:watch"],
      "cache": false,
      "persistent": true,
      "env": [
        "MONGO_URI",
        "EVM_URL",
        "ACCOUNTS_URL",
        "CLIENT_ID",
        "CLIENT_SECRET",
        "EVM_RPC_URL",
        "EVM_CONTENT_NFT_CONTRACT_ADDRESS",
        "EVM_LICENSE_NTF_CONTRACT_ADDRESS",
        "R2_ACCESS_KEY",
        "R2_SECRET_KEY",
        "R2_METADATA_BUCKET_HOST"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "env": ["PORT", "NODE_ENV"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "cache": false
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    }
  }
}
