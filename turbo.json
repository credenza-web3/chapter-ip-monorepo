{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "tui",
  "globalEnv": ["PORT", "NODE_ENV", "ACCOUNTS_URL"],
  "tasks": {
    "trpc:generate": {
      "cache": false,
      "persistent": false,
    },
    "build": {
      "dependsOn": [/*"backend#trpc:generate",*/ "^build"],
      "env": ["PORT", "NODE_ENV", "ACCOUNTS_URL"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "cache": false
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
  }
}
