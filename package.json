{
  "name": "chapter-ip-monorepo",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{js,ts,tsx,svelte,md,html,json}\"",
    "trpc:generate": "turbo run trpc:generate",
    "check-types": "turbo run check-types",
    "ncu": "pnpm dlx npm-check-updates --deep -i",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.0",
    "turbo": "^2.8.10",
    "typescript": "5.9.3"
  },
  "packageManager": "pnpm@10.30.2",
  "engines": {
    "node": ">=22"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
