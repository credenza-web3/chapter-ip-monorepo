{
  "name": "chapter-ip-monorepo",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{js,ts,tsx,svelte,md,html,json}\"",
    "trpc:generate": "turbo run trpc:generate",
    "check-types": "turbo run check-types",
    "prepare": "husky",
    "postinstall": "pnpm run trpc:generate"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "prettier": "^3.7.4",
    "prettier-plugin-svelte": "^3.4.0",
    "turbo": "^2.6.3",
    "typescript": "5.9.3"
  },
  "packageManager": "pnpm@10.25.0",
  "engines": {
    "node": ">=22"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
