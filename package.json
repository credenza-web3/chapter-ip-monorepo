{
  "name": "chapter-ip-monorepo",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{js,ts,tsx,svelte,md,html,json,css}\"",
    "trpc:chmod": "chmod +x node_modules/.pnpm/nestjs-trpc@*/node_modules/nestjs-trpc/native/**/*",
    "trpc:generate": "nestjs-trpc generate --output packages/trpc/src/server/server.ts --entrypoint apps/backend/main.ts",
    "trpc:watch": "sleep 3 && nestjs-trpc watch --output packages/trpc/src/server/server.ts --entrypoint apps/backend/main.ts",
    "check-types": "turbo run check-types",
    "ncu": "pnpm dlx npm-check-updates --deep -i",
    "prepare": "husky",
    "postinstall": "pnpm run trpc:chmod"
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "eslint": "^10.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.1.0",
    "nestjs-trpc": "^2.12.0",
    "prettier": "^3.9.6",
    "prettier-plugin-svelte": "^4.1.1",
    "turbo": "^2.10.5",
    "typescript": "6.0.3"
  },
  "packageManager": "pnpm@11.15.1",
  "engines": {
    "node": ">=24"
  }
}
